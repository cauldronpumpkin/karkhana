{
  "identifier": "default",
  "description": "Default capabilities for the worker app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "shell:allow-open",
    "autostart:default",
    "updater:default"
  ]
}
