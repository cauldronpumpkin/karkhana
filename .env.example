# LM Studio Configuration
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL_NAME=qwen-3-coder-next
LM_STUDIO_MAX_CONCURRENCY=1

# LLM Parameters
MAX_TOKENS=8192
TEMPERATURE_CREATIVE=0.7
TEMPERATURE_CODING=0.2
TIMEOUT_SECONDS=300
MAX_RETRIES=5

# Sandbox Configuration
SANDBOX_TIMEOUT=120
MAX_RETRIES_PER_FILE=3

# Agent Communication Feature Flags
AGENT_COMMS_ENABLED=false
AGENT_COMMS_MAX_ROUNDS=8
AGENT_COMMS_ESCALATE_BLOCKING_ONLY=true

# Tool Calling Controls
TOOL_CALLING_ENABLED=true
TOOL_CALLING_FALLBACK_ENABLED=true
TOOL_CALLING_MAX_ROUNDS=4
TOOL_CALLING_FILE_TOOL_MAX_CHARS=12000

# Reasoning Controls
REASONING_ENABLED=false
REASONING_PROFILE=balanced
REASONING_ARCHITECT_TOT_PATHS=3
REASONING_ARCHITECT_TOT_PARALLEL=true
REASONING_CRITIC_ENABLED=true
REASONING_THINKING_MODULES_ENABLED=true
REASONING_THINKING_VISIBILITY=logs
REASONING_TDD_ENABLED=true
REASONING_TDD_TIME_SPLIT_PERCENT=40
REASONING_TDD_MAX_ITERATIONS=5
REASONING_TDD_FAIL_OPEN=true
